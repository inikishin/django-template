# Copy this file to .env and fill in the values.
DEBUG=1
SECRET_KEY=change-me
ALLOWED_HOSTS=localhost,127.0.0.1

# API location prefix (e.g. "api" -> /api/...). Leave empty to serve at root.
API_PREFIX=api
# Port the service listens on.
PORT=8000

# DB by default is sqlite (no settings needed). For postgres see the initial-setup skill.
